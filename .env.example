# =============================================================================
# Mission Barisal v3 — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# Server Port
PORT=5010

# Domain Detection (IMPORTANT for multi-server deployment)
# Set this to your domain for proper identity detection
DEPLOY_DOMAIN=m.skilltoearn.org

# Session Verification
SESSION_VERIFY_URL=http://zombiecoder.my.id/api/verify-session

# Pusher (optional — for real-time notifications)
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=ap2

# Cache Settings
CACHE_DIR=./cache
CACHE_TTL=86400000
CACHE_MAX_ENTRIES=1000

# Log Settings
LOG_DIR=./logs

# Rate Limit Override (optional)
# MAX_RATE_LIMIT=50

# CORS Override (optional — comma-separated origins)
# ALLOWED_ORIGINS=https://m.skilltoearn.org,http://localhost:5010

# Anti-Dote Type Safety (default: true)
# ANTIDOTE_ENABLED=true
